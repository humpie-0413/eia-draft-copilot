# PostgreSQL + PostGIS
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eia_copilot

# App
DEBUG=true

# 공공데이터포털 API 키 (https://www.data.go.kr/ 에서 발급)
# 에어코리아 대기오염정보, 국립환경과학원 수질 DB 등 공공데이터 API 호출에 사용
DATA_GO_KR_API_KEY=

# OpenAI API 키
OPENAI_API_KEY=

# Google API 키
GOOGLE_API_KEY=

# 커넥터 외부 API 호출 타임아웃 (초, 기본값 30)
CONNECTOR_TIMEOUT=30
